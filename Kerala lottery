<script>
    let activeTicketsCollection = [];
    const itemCostUnit = 40;

    // Failover Routine Execution for Image Error
    function applyBackupAsset() {
        const imageElement = document.getElementById('mainBannerImg');
        // If main image fails to load, gracefully load the backup layout file
        imageElement.src = '1000015921.jpg';
    }

    // Interactive Notification Deck
    const simulatorPool = [
        { alias: "Rahul", city: "Palakkad", volume: 5 },
        { alias: "Anjali", city: "Kochi", volume: 12 },
        { alias: "Vikram", city: "Trivandrum", volume: 8 },
        { alias: "Suresh", city: "Kozhikode", volume: 15 },
        { alias: "Priya", city: "Ernakulam", volume: 4 },
        { alias: "Ramesh", city: "Bangalore", volume: 10 }
    ];
    let simulatorPointer = 0;

    setInterval(() => {
        const elementToast = document.getElementById('liveToastNotification');
        elementToast.style.transform = 'translateY(12px)';
        elementToast.style.opacity = '0';
        
        setTimeout(() => {
            const dataNode = simulatorPool[simulatorPointer];
            document.getElementById('popupClientName').innerText = dataNode.alias;
            document.getElementById('popupClientLoc').innerText = dataNode.city;
            document.getElementById('popupTicketQty').innerText = dataNode.volume;
            document.getElementById('popupPriceCalculated').innerText = dataNode.volume * itemCostUnit;
            
            elementToast.style.transform = 'translateY(0)';
            elementToast.style.opacity = '1';
            simulatorPointer = (simulatorPointer + 1) % simulatorPool.length;
        }, 4000);
    }, 5000);

    function toggleSelection(domReference, ticketUid) {
        if (domReference.classList.contains('selected')) {
            domReference.classList.remove('selected');
            activeTicketsCollection = activeTicketsCollection.filter(id => id !== ticketUid);
        } else {
            domReference.classList.add('selected');
            activeTicketsCollection.push(ticketUid);
        }
        document.getElementById('runningTotal').innerText = activeTicketsCollection.length * itemCostUnit;
    }

    function processOrder() {
        const clientProfileName = document.getElementById('buyerName').value.trim();
        const clientProfilePhone = document.getElementById('buyerContact').value.trim();
        const calculationAggregate = activeTicketsCollection.length * itemCostUnit;

        if (!clientProfileName || !clientProfilePhone) {
            alert("कृपया अपना नाम और व्हाट्सएप नंबर दर्ज करें।");
            return;
        }

        if (activeTicketsCollection.length === 0) {
            alert("कृपया आगे बढ़ने के लिए कम से कम एक टिकट चुनें।");
            return;
        }

        // Processing Message Text String Structure
        const messageString = `*🟢 NEW KERALA LOTTERY BOOKING* %0A%0A` +
                              `*👤 Name:* ${clientProfileName}%0A` +
                              `*📱 Mobile:* ${clientProfilePhone}%0A%0A` +
                              `*🎟️ Selected Tickets (${activeTicketsCollection.length}):*%0A${activeTicketsCollection.map(id => `• ${id}`).join('%0A')}%0A%0A` +
                              `*💰 Total Price:* ₹${calculationAggregate}/-`;

        // Updated Target WhatsApp API Gateway Integration
        const coreGatewayNumber = "919709981588";
        window.open(`https://wa.me/${coreGatewayNumber}?text=${messageString}`, '_blank');
    }
</script>

