<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Official Kerala Lottery Online Booking Portal</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --primary-emerald: #00a859;
            --dark-emerald: #008744;
            --accent-crimson: #e91e63;
            --focus-blue: #2b6cb0;
            --canvas-bg: #f8fafc;
            --slate-gray: #4a5568;
            --light-border: #e2e8f0;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        }

        body {
            background-color: var(--canvas-bg);
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 16px;
            color: #2d3748;
        }

        .phone-mockup-container {
            background: #ffffff;
            max-width: 450px;
            width: 100%;
            border-radius: 24px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.1), 0 10px 20px -6px rgba(0, 0, 0, 0.05);
            overflow: hidden;
            position: relative;
            border: 1px solid rgba(226, 232, 240, 0.8);
        }

        /* Hero Banner Image Slot with Failover Aspect Ratio */
        .banner-viewport {
            position: relative;
            width: 100%;
            aspect-ratio: 16 / 7.2;
            background: #111827;
            overflow: hidden;
        }

        .banner-viewport img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
            transition: opacity 0.3s ease;
        }

        /* Dynamic Popup Overlay */
        .live-alert-toast {
            position: absolute;
            bottom: 12px;
            left: 16px;
            right: 16px;
            background: rgba(255, 255, 255, 0.98);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-left: 4px solid var(--primary-emerald);
            padding: 12px 16px;
            border-radius: 14px;
            font-size: 13px;
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.15);
            display: flex;
            align-items: center;
            gap: 12px;
            transform: translateY(0);
            opacity: 1;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            z-index: 10;
        }

        .toast-icon-wrapper {
            background: #e8f5e9;
            color: var(--primary-emerald);
            width: 36px;
            height: 36px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            flex-shrink: 0;
        }

        /* Verification Indicator Bar */
        .badge-assurance-strip {
            background: #f1f5f9;
            border-bottom: 1px solid var(--light-border);
            padding: 10px 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            font-weight: 600;
            font-size: 13px;
            color: var(--slate-gray);
        }

        .live-pulse-container {
            display: flex;
            align-items: center;
            gap: 6px;
            color: var(--primary-emerald);
        }

        .pulse-dot {
            width: 8px;
            height: 8px;
            background-color: var(--primary-emerald);
            border-radius: 50%;
            animation: radialGlow 1.8s infinite ease-in-out;
        }

        @keyframes radialGlow {
            0% { transform: scale(0.8); opacity: 0.5; }
            50% { transform: scale(1.2); opacity: 1; }
            100% { transform: scale(0.8); opacity: 0.5; }
        }

        /* Form Layout Elements */
        .form-workspace {
            padding: 20px;
        }

        .input-block {
            margin-bottom: 16px;
        }

        .input-block label {
            display: block;
            font-size: 12px;
            color: #718096;
            font-weight: 700;
            margin-bottom: 6px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .interactive-input-shell {
            position: relative;
            display: flex;
            align-items: center;
        }

        .interactive-input-shell i {
            position: absolute;
            left: 16px;
            color: #a0aec0;
            font-size: 15px;
            pointer-events: none;
        }

        .interactive-input-shell input {
            width: 100%;
            padding: 13px 16px 13px 44px;
            border: 1.5px solid #cbd5e0;
            border-radius: 12px;
            font-size: 15px;
            font-weight: 500;
            outline: none;
            color: #1a202c;
            transition: all 0.2s ease;
        }

        .interactive-input-shell input:focus {
            border-color: var(--focus-blue);
            box-shadow: 0 0 0 3px rgba(66, 153, 225, 0.15);
        }

        /* Custom Content Scroll Area */
        .ticket-inventory-container {
            border: 1.5px dashed #f48fb1;
            border-radius: 16px;
            padding: 16px;
            background: #fffdfd;
            margin-bottom: 20px;
        }

        .inventory-legend {
            color: #c2185b;
            font-weight: 700;
            font-size: 14px;
            margin-bottom: 12px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .ticket-scroll-grid {
            max-height: 240px;
            overflow-y: auto;
            border: 1px solid var(--light-border);
            border-radius: 12px;
            background: #ffffff;
        }

        .ticket-row-node {
            padding: 12px 18px;
            border-bottom: 1px solid #f1f5f9;
            cursor: pointer;
            font-weight: 700;
            color: var(--slate-gray);
            font-size: 14.5px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            transition: background 0.15s ease;
        }

        .ticket-row-node:last-child {
            border-bottom: none;
        }

        .ticket-row-node:hover {
            background: #f8fafc;
        }

        .ticket-row-node.selected {
            background-color: #ebf8ff;
            color: var(--focus-blue);
        }

        .ticket-row-node .checkbox-ui {
            width: 20px;
            height: 20px;
            border: 2px solid #cbd5e0;
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 11px;
            color: transparent;
            transition: all 0.15s ease;
        }

        .ticket-row-node.selected .checkbox-ui {
            border-color: var(--focus-blue);
            background: var(--focus-blue);
            color: #ffffff;
        }

        /* Statement Balance Bar */
        .summary-billboard {
            background: #f8fafc;
            border-radius: 12px;
            padding: 14px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            border: 1px solid var(--light-border);
        }

        .billboard-text {
            font-size: 14px;
            color: #718096;
            font-weight: 600;
        }

        .billboard-total-value {
            font-size: 20px;
            font-weight: 800;
            color: #1a202c;
        }

        /* Primary Action Dispatcher */
        .action-button-trigger {
            width: 100%;
            background: var(--primary-emerald);
            color: #ffffff;
            border: none;
            padding: 16px;
            border-radius: 14px;
            font-size: 16px;
            font-weight: 700;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            box-shadow: 0 4px 14px rgba(0, 168, 89, 0.25);
            transition: all 0.2s ease;
        }

        .action-button-trigger:hover {
            background: var(--dark-emerald);
            box-shadow: 0 6px 20px rgba(0, 168, 89, 0.35);
        }
    </style>
</head>
